{
  "name": "reuse-before-generate",
  "version": "0.1.0",
  "description": "MCP tool: before scaffolding a new project, check whether it already exists and suggest extending a maintained alternative instead of rebuilding.",
  "type": "module",
  "bin": {
    "reuse-before-generate": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "npm run build && node --test test/unit/*.test.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
